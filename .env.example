# Contact form (src/app/api/contact/route.ts) — enquiries are emailed via Resend.
# Copy this file to .env.local and fill in your values, then restart the dev server.

# Required. Create a key at https://resend.com/api-keys
RESEND_API_KEY=

# Where consultation enquiries are delivered.
CONTACT_TO=contact@acedigitalsolutions.co.uk

# Verified Resend sender. Until you verify your domain you can use the
# Resend sandbox sender below; switch to your domain for production.
# CONTACT_FROM=Ace Digital Solutions <noreply@acedigitalsolutions.co.uk>
CONTACT_FROM=Ace Digital Solutions <onboarding@resend.dev>
